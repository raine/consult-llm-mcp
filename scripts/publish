#!/usr/bin/env bash
set -euo pipefail

bump="${1:-}"

if [[ -z "$bump" ]]; then
	echo "usage: scripts/publish <patch|minor|major|beta>" >&2
	exit 1
fi

if [[ "$bump" != "patch" && "$bump" != "minor" && "$bump" != "major" && "$bump" != "beta" ]]; then
	echo "error: bump must be patch, minor, major, or beta (got: $bump)" >&2
	exit 1
fi

BETA=false
if [[ "$bump" == "beta" ]]; then
	BETA=true
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
	echo "error: working tree has uncommitted changes" >&2
	exit 1
fi

if [[ "$BETA" == false ]]; then
	echo "Running checks..."
	cargo clippy --workspace --all-targets -- -D clippy::all
	cargo test --workspace
fi

# Rollback version files on any failure after this point
cleanup() {
	rc=$?
	if [ $rc -ne 0 ]; then
		echo "Failure detected, rolling back version changes..." >&2
		git restore package.json Cargo.toml Cargo.lock 2>/dev/null || true
	fi
	exit $rc
}
trap cleanup EXIT

if [[ "$BETA" == true ]]; then
	npm version prepatch --preid=beta --no-git-tag-version
else
	npm version "$bump" --no-git-tag-version
fi
VERSION=$(node -p "require('./package.json').version")

# Sync version to Cargo.toml
sed -i '' "s/^version = \".*\"/version = \"$VERSION\"/" Cargo.toml
cargo check --quiet 2>/dev/null # update Cargo.lock

trap - EXIT

git add package.json Cargo.toml Cargo.lock
git commit -m "$VERSION"
git tag "v$VERSION"
git push
git push --tags

echo ""
echo "Pushed v${VERSION} — CI will build and publish."
