#!/usr/bin/env bash
set -euo pipefail

bump="${1:-}"

if [[ -z "$bump" ]]; then
	echo "usage: scripts/publish <patch|minor|major|beta>" >&2
	exit 1
fi

if [[ "$bump" != "patch" && "$bump" != "minor" && "$bump" != "major" && "$bump" != "beta" ]]; then
	echo "error: bump must be patch, minor, major, or beta (got: $bump)" >&2
	exit 1
fi

BETA=false
if [[ "$bump" == "beta" ]]; then
	BETA=true
fi

# Pre-flight checks
echo "Checking npm auth..."
npm whoami

for cmd in cargo cargo-zigbuild zig; do
	if ! command -v "$cmd" >/dev/null 2>&1; then
		echo "error: $cmd is not installed" >&2
		exit 1
	fi
done

echo "Ensuring rust targets are installed..."
rustup target add aarch64-apple-darwin x86_64-apple-darwin x86_64-unknown-linux-gnu aarch64-unknown-linux-gnu

if ! git diff --quiet || ! git diff --cached --quiet; then
	echo "error: working tree has uncommitted changes" >&2
	exit 1
fi

if [[ "$BETA" == false ]]; then
	# Non-mutating checks
	echo "Running checks..."
	cargo clippy --workspace --all-targets -- -D clippy::all
	cargo test --workspace
fi

# Rollback version files on any failure after this point
cleanup() {
	rc=$?
	if [ $rc -ne 0 ]; then
		echo "Failure detected, rolling back version changes..." >&2
		git restore package.json Cargo.toml Cargo.lock 2>/dev/null || true
	fi
	exit $rc
}
trap cleanup EXIT

if [[ "$BETA" == true ]]; then
	# Beta: bump to next patch prerelease (e.g., 2.5.4 -> 2.5.5-beta.0)
	npm version prepatch --preid=beta --no-git-tag-version
else
	# Release: bump normally
	npm version "$bump" --no-git-tag-version
fi
VERSION=$(node -p "require('./package.json').version")

# Sync version to Cargo.toml
sed -i '' "s/^version = \".*\"/version = \"$VERSION\"/" Cargo.toml
cargo check --quiet 2>/dev/null # update Cargo.lock

# Cross-compile binaries
echo "Building aarch64-apple-darwin..."
cargo build --release --target aarch64-apple-darwin

echo "Building x86_64-apple-darwin..."
cargo build --release --target x86_64-apple-darwin

echo "Building x86_64-unknown-linux-gnu..."
cargo zigbuild --release --target x86_64-unknown-linux-gnu

echo "Building aarch64-unknown-linux-gnu..."
cargo zigbuild --release --target aarch64-unknown-linux-gnu

# Stage for publishing
echo "Staging release..."
STAGE_DIR="target/npm-package"
rm -rf "$STAGE_DIR"
mkdir -p "$STAGE_DIR"

# Platform mapping: rust_target:os:cpu:suffix[:libc]
platforms=(
	"aarch64-apple-darwin:darwin:arm64:darwin-arm64"
	"x86_64-apple-darwin:darwin:x64:darwin-x64"
	"x86_64-unknown-linux-gnu:linux:x64:linux-x64:glibc"
	"aarch64-unknown-linux-gnu:linux:arm64:linux-arm64:glibc"
)

# Stage platform-specific packages
for plat in "${platforms[@]}"; do
	IFS=":" read -r target os cpu suffix libc <<< "$plat"
	pkg_name="consult-llm-mcp-$suffix"
	pkg_dir="$STAGE_DIR/$pkg_name"
	mkdir -p "$pkg_dir"

	libc_field=""
	if [ -n "$libc" ]; then
		libc_field=$(printf ',\n  "libc": ["%s"]' "$libc")
	fi

	cat > "$pkg_dir/package.json" <<-PKGJSON
	{
	  "name": "$pkg_name",
	  "version": "$VERSION",
	  "description": "Platform binary for consult-llm-mcp ($suffix)",
	  "os": ["$os"],
	  "cpu": ["$cpu"]${libc_field},
	  "files": ["consult-llm-mcp"],
	  "license": "MIT"
	}
	PKGJSON

	cp "target/$target/release/consult-llm-mcp" "$pkg_dir/consult-llm-mcp"
	chmod +x "$pkg_dir/consult-llm-mcp"

	echo "Validating $pkg_name..."
	(cd "$pkg_dir" && npm pack --dry-run)
done

# Stage root wrapper package
root_dir="$STAGE_DIR/consult-llm-mcp"
mkdir -p "$root_dir"
cp package.json README.md CHANGELOG.md LICENSE run.sh "$root_dir/"
chmod +x "$root_dir/run.sh"

# Inject optionalDependencies into staged package.json
ROOT_DIR="$root_dir" VERSION="$VERSION" node -e '
const fs = require("fs");
const pkg = JSON.parse(fs.readFileSync(process.env.ROOT_DIR + "/package.json", "utf8"));
pkg.optionalDependencies = {
  "consult-llm-mcp-darwin-arm64": process.env.VERSION,
  "consult-llm-mcp-darwin-x64": process.env.VERSION,
  "consult-llm-mcp-linux-x64": process.env.VERSION,
  "consult-llm-mcp-linux-arm64": process.env.VERSION
};
fs.writeFileSync(process.env.ROOT_DIR + "/package.json", JSON.stringify(pkg, null, 2) + "\n");
'

echo "Validating root package..."
(cd "$root_dir" && npm pack --dry-run)

# Use automation token if available (no 2FA needed)
if [ -n "${CONSULT_LLM_MCP_NPM_PUBLISH_TOKEN:-}" ]; then
	export NPM_CONFIG_TOKEN="$CONSULT_LLM_MCP_NPM_PUBLISH_TOKEN"
	echo "Using CONSULT_LLM_MCP_NPM_PUBLISH_TOKEN for auth"
fi

NPM_TAG_FLAG=""
if [[ "$BETA" == true ]]; then
	NPM_TAG_FLAG="--tag beta"
fi

# Publish platform packages first (skip if already published for resumability)
for plat in "${platforms[@]}"; do
	IFS=":" read -r target os cpu suffix libc <<< "$plat"
	pkg_name="consult-llm-mcp-$suffix"
	pkg_dir="$STAGE_DIR/$pkg_name"

	if npm view "$pkg_name@$VERSION" version >/dev/null 2>&1; then
		echo "$pkg_name@$VERSION already published, skipping..."
	else
		echo "Publishing $pkg_name@$VERSION..."
		(cd "$pkg_dir" && npm publish $NPM_TAG_FLAG)
	fi
done

# Publish root wrapper package
if npm view "consult-llm-mcp@$VERSION" version >/dev/null 2>&1; then
	echo "consult-llm-mcp@$VERSION already published, skipping..."
else
	echo "Publishing consult-llm-mcp@$VERSION..."
	(cd "$root_dir" && npm publish $NPM_TAG_FLAG)
fi

if [[ "$BETA" == true ]]; then
	echo ""
	echo "Published beta v${VERSION}"
	echo "Test with: npx consult-llm-mcp@beta"
	echo ""
	echo "Rolling back version files (beta does not commit)..."
	git restore package.json Cargo.toml Cargo.lock 2>/dev/null || true
	# Disable cleanup trap since we handled rollback
	trap - EXIT
else
	# Commit and tag only after successful publish
	git add package.json Cargo.toml Cargo.lock
	git commit -m "$VERSION"
	git tag "v$VERSION"
	git push
	git push --tags

	echo "Published v${VERSION}"
fi
