#!/usr/bin/env bash
#
# Install/uninstall consult-llm-mcp skills globally
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/raine/consult-llm-mcp/main/scripts/install-skills | bash
#   curl -fsSL https://raw.githubusercontent.com/raine/consult-llm-mcp/main/scripts/install-skills | bash -s uninstall
#
# Supported platforms:
#   Claude Code  ~/.claude/skills/
#   OpenCode     ~/.config/opencode/skills/
#   Codex        ~/.codex/skills/
#

set -euo pipefail

repo="raine/consult-llm-mcp"
branch="main"
base_url="https://raw.githubusercontent.com/$repo/$branch"

skills=(
	collab
	collab-vs
	consult
	debate
	debate-vs
)

red='\033[0;31m'
green='\033[0;32m'
yellow='\033[1;33m'
blue='\033[0;34m'
nc='\033[0m'

log_ok() { echo -e "  ${green}✓${nc} $1"; }
log_warn() { echo -e "  ${yellow}!${nc} $1"; }
log_err() { echo -e "${red}✗${nc} $1" >&2; }

# Each entry: "platform_name|skills_dir|config_dir_to_detect"
platform_defs=(
	"Claude Code|$HOME/.claude/skills|$HOME/.claude"
	"OpenCode|$HOME/.config/opencode/skills|$HOME/.config/opencode"
	"Codex|$HOME/.codex/skills|$HOME/.codex"
)

install_platform() {
	local platform_name="$1"
	local skills_dest="$2"
	local installed=0

	echo -e "${blue}==>${nc} ${platform_name}"

	for name in "${skills[@]}"; do
		local url="$base_url/skills/$name/SKILL.md"
		local dest_dir="$skills_dest/$name"

		mkdir -p "$dest_dir"
		if curl -fsSL "$url" -o "$dest_dir/SKILL.md"; then
			log_ok "$name"
			installed=$((installed + 1))
		else
			log_warn "Failed to download $name"
			rmdir "$dest_dir" 2>/dev/null || true
		fi
	done

	echo "  Installed $installed skill(s) to $skills_dest"
	echo ""
}

uninstall_platform() {
	local platform_name="$1"
	local skills_dest="$2"
	local removed=0

	echo -e "${blue}==>${nc} ${platform_name}"

	for name in "${skills[@]}"; do
		local dest_dir="$skills_dest/$name"

		if [[ -d "$dest_dir" ]]; then
			rm -rf "$dest_dir"
			log_ok "Removed $name"
			removed=$((removed + 1))
		else
			log_warn "Not installed: $name"
		fi
	done

	echo "  Removed $removed skill(s)"
	echo ""
}

run_for_platforms() {
	local action="$1"
	local found=0

	for def in "${platform_defs[@]}"; do
		IFS='|' read -r name skills_dir config_dir <<< "$def"
		[[ -d "$config_dir" ]] || continue
		found=$((found + 1))
		"${action}_platform" "$name" "$skills_dir"
	done

	if [[ "$found" -eq 0 ]]; then
		log_err "No supported platforms detected"
		echo "Expected one of: ~/.claude/, ~/.config/opencode/, ~/.codex/"
		exit 1
	fi
}

case "${1:-install}" in
install)
	run_for_platforms install
	;;
uninstall)
	run_for_platforms uninstall
	;;
*)
	log_err "Unknown command: $1"
	echo "Usage: $(basename "$0") [install|uninstall]"
	exit 1
	;;
esac
